rules_version = '2';
// OMW – On My Way  |  Firestore Security Rules
// Project: swiftgo-b74fb  |  Hardened: 2026-06-03
//
// HOW TO DEPLOY:
//   firebase deploy --only firestore:rules --project swiftgo-b74fb
//
// Role model: custom claims not yet implemented. Roles stored in users/{uid}.roles.
// Role escalation is blocked via field-level write restrictions on users/{uid}.
// Protected privileged roles: 'owner', 'admin'
// Self-assignable roles: 'customer', 'worker', 'storeOwner'
//
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userRole() {
      return request.auth.token.get('role', '');
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfileRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && role in userDoc().data.get('roles', []);
    }

    function isOwnerOrAdmin() {
      return isSignedIn()
        && (
          userRole() in ['owner', 'admin']
          || hasProfileRole('owner')
          || hasProfileRole('admin')
        );
    }

    function isStoreOwnerOrAdmin() {
      return isSignedIn()
        && (
          userRole() in ['storeOwner', 'owner']
          || hasProfileRole('storeOwner')
          || hasProfileRole('owner')
          || hasProfileRole('admin')
        );
    }

    function isWorkerOrAdmin() {
      return isSignedIn()
        && (
          userRole() in ['worker', 'owner']
          || hasProfileRole('worker')
          || hasProfileRole('owner')
          || hasProfileRole('admin')
        );
    }

    // -------------------------------------------------------------------------
    // USERS — role escalation prevention
    //
    // Key invariant: only admin/owner can assign privileged roles (owner/admin).
    // Users may add non-privileged roles (customer, worker, storeOwner) to their
    // own document, which is necessary for the self-registration flow.
    // Bootstrap admin email sets 'owner' role at document CREATION time only.
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if (isSignedIn() && uid() == userId) || isOwnerOrAdmin();

      // First-time document creation (new user registration / bootstrap).
      // Privileged roles can be set here only — subsequent updates are gated.
      allow create: if isSignedIn() && uid() == userId;

      // Updates: user may change safe profile fields.
      // If roles/role/activeRole are being changed the resulting roles array
      // must NOT contain 'owner' or 'admin' (non-escalation invariant).
      // Existing admin/owner users satisfy isOwnerOrAdmin() via the write rule.
      allow update: if isSignedIn() && uid() == userId
        && (
          // Not touching roles fields at all — any other field change allowed
          !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['roles', 'role', 'activeRole'])
          // OR changing roles but result must contain no privileged role
          || !request.resource.data.get('roles', []).hasAny(['owner', 'admin'])
        );

      // Admin/owner can read and write everything, including role assignment
      allow write: if isOwnerOrAdmin();
    }

    // -------------------------------------------------------------------------
    // MARKETPLACE — stores
    // -------------------------------------------------------------------------
    match /stores/{storeId} {
      // Public browsing of approved/active stores; owner sees all; store owner
      // sees own profile regardless of status.
      allow read: if resource.data.status in ['approved', 'active']
        || isOwnerOrAdmin()
        || (isSignedIn() && resource.data.ownerId == uid());

      // Store owner creates their own store — status must start as pending.
      // Cannot pre-populate admin approval fields.
      allow create: if isOwnerOrAdmin()
        || (isSignedIn() && isStoreOwnerOrAdmin()
            && request.resource.data.ownerId == uid()
            && request.resource.data.get('status', 'pending') in ['pending', 'inactive']
            && request.resource.data.get('storeStatus', 'pending') in ['pending', 'inactive']
            && !request.resource.data.keys().hasAny(['approvedAt', 'approvedByAdminId']));

      // Store owner updates safe fields (name, address, hours, category, etc.).
      // approval status must stay unchanged — only admin can approve/reject/suspend.
      // Admin-only audit fields (approvedAt, approvedByAdminId, etc.) are blocked.
      allow update: if isOwnerOrAdmin()
        || (isSignedIn() && isStoreOwnerOrAdmin()
            && resource.data.ownerId == uid()
            && request.resource.data.ownerId == uid()
            // Status value must not change (admin gates approval)
            && request.resource.data.get('status', resource.data.status) == resource.data.status
            && request.resource.data.get('storeStatus', resource.data.status) == resource.data.status
            // Admin-only audit fields must not be touched
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['approvedAt', 'approvedByAdminId', 'rejectionReason',
                          'rejectedAt', 'suspendedAt', 'featuredEnabled']));

      allow delete: if isOwnerOrAdmin();
    }

    // -------------------------------------------------------------------------
    // MARKETPLACE — products
    // -------------------------------------------------------------------------
    match /products/{productId} {
      // Public reads only for products belonging to approved/active stores.
      allow read: if isOwnerOrAdmin()
        || (isSignedIn() && resource.data.storeOwnerId == uid())
        || (exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
            && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.status
               in ['approved', 'active']);

      // Store owner creates product only for a store they own.
      allow create: if isOwnerOrAdmin()
        || (isSignedIn() && isStoreOwnerOrAdmin()
            && request.resource.data.storeOwnerId == uid()
            && exists(/databases/$(database)/documents/stores/$(request.resource.data.storeId))
            && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == uid());

      // Store owner updates product only for a store they own; storeId cannot change.
      allow update: if isOwnerOrAdmin()
        || (isSignedIn() && isStoreOwnerOrAdmin()
            && resource.data.storeOwnerId == uid()
            && request.resource.data.storeOwnerId == uid()
            && resource.data.storeId == request.resource.data.storeId);

      allow delete: if isOwnerOrAdmin()
        || (isSignedIn() && isStoreOwnerOrAdmin() && resource.data.storeOwnerId == uid());
    }

    // -------------------------------------------------------------------------
    // MARKETPLACE — product categories
    // -------------------------------------------------------------------------
    match /productCategories/{catId} {
      allow read: if true;
      // Only the store owner of the target store may write categories.
      allow create, update: if isOwnerOrAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/stores/$(request.resource.data.storeId))
            && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == uid());
      allow delete: if isOwnerOrAdmin();
    }

    // -------------------------------------------------------------------------
    // MARKETPLACE ORDERS
    // -------------------------------------------------------------------------
    match /marketplaceOrders/{orderId} {
      // Customers read own orders. Store owners read their store's orders.
      // Workers see awaitingWorker orders or their own assigned deliveries.
      // Admin/owner read all.
      allow read: if isOwnerOrAdmin()
        || (isSignedIn() && resource.data.customerId == uid())
        || (isSignedIn() && resource.data.storeOwnerId == uid())
        // Workers see orders awaiting delivery dispatch or their own assigned order
        || (isWorkerOrAdmin()
            && (resource.data.get('deliveryStatus', '') == 'awaitingWorker'
                || resource.data.get('assignedWorkerId', '') == uid()));

      // Authenticated customers create orders.
      // deliveryStatus must be absent or 'none'; worker fields are forbidden.
      allow create: if isSignedIn()
        && request.resource.data.customerId == uid()
        && request.resource.data.get('status', 'pending') == 'pending'
        && request.resource.data.get('deliveryStatus', 'none') == 'none'
        && !request.resource.data.keys()
             .hasAny(['assignedWorkerId', 'assignedWorkerName', 'assignedWorkerPhone',
                      'deliveredAt', 'pickedUpAt', 'approvedAt']);

      // Store owner updates allowed statuses; cannot touch worker assignment
      // fields. Setting deliveryStatus=awaitingWorker is allowed when marking
      // the order pickedUp (store-ready) — service layer handles this together.
      allow update: if isOwnerOrAdmin()
        || (isSignedIn()
            && resource.data.storeOwnerId == uid()
            && request.resource.data.storeOwnerId == uid()
            && request.resource.data.customerId == resource.data.customerId
            && request.resource.data.get('status', '') in
               ['pending', 'accepted', 'shopping', 'pickedUp', 'cancelled']
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['customerId', 'total', 'items',
                          'assignedWorkerId', 'assignedWorkerName', 'assignedWorkerPhone']))
        // Worker claiming an available delivery (awaitingWorker → assigned)
        || (isWorkerOrAdmin()
            && resource.data.get('deliveryStatus', '') == 'awaitingWorker'
            && request.resource.data.get('deliveryStatus', '') == 'assigned'
            && request.resource.data.get('assignedWorkerId', '') == uid()
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['customerId', 'storeOwnerId', 'total', 'items',
                          'status', 'storeAddress', 'storeLat', 'storeLng']))
        // Worker updating own assigned delivery (pickedUp → onTheWay → delivered)
        || (isWorkerOrAdmin()
            && resource.data.get('assignedWorkerId', '') == uid()
            && request.resource.data.get('assignedWorkerId', '') == uid()
            && request.resource.data.get('deliveryStatus', '') in
               ['pickedUp', 'onTheWay', 'delivered', 'cancelled', 'failed']
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['customerId', 'storeOwnerId', 'total', 'items']));

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // STORE EXPENSES — store owner financial records
    // -------------------------------------------------------------------------
    match /storeExpenses/{expenseId} {
      allow read: if isOwnerOrAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
            && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == uid());
      allow create: if isOwnerOrAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/stores/$(request.resource.data.storeId))
            && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == uid());
      allow update, delete: if isOwnerOrAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/stores/$(resource.data.storeId))
            && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == uid());
    }

    // -------------------------------------------------------------------------
    // WORKERS — role escalation prevention
    //
    // Workers control their own profile fields but cannot approve themselves.
    // submitApplication sets status→pending: allowed.
    // approveWorker/rejectWorker set status→approved/rejected: admin only.
    // -------------------------------------------------------------------------
    match /workers/{workerId} {
      allow read: if isSignedIn()
        && (uid() == workerId || isOwnerOrAdmin());

      // Worker creates their own profile; initial status must be incomplete/pending.
      // Cannot inject approval audit fields at creation.
      allow create: if isOwnerOrAdmin()
        || (isSignedIn() && uid() == workerId
            && request.resource.data.get('status', 'incomplete') in ['incomplete', 'pending']
            && request.resource.data.get('workerStatus', 'incomplete')
               in ['incomplete', 'pending_approval']
            && !request.resource.data.keys()
                 .hasAny(['approvedAt', 'approvedByAdminId', 'rejectionReason',
                          'suspendedAt']));

      // Worker updates own profile.
      // Approval audit fields are frozen; status may only move to incomplete/pending.
      // platformCommissionRate/workerPayoutRate may be set only to standard values.
      allow update: if isOwnerOrAdmin()
        || (isSignedIn() && uid() == workerId
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['approvedAt', 'approvedByAdminId', 'rejectedAt',
                          'rejectionReason', 'suspendedAt'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['status', 'workerStatus'])
              || (request.resource.data.get('status', 'incomplete') in ['incomplete', 'pending']
                  && request.resource.data.get('workerStatus', 'incomplete')
                     in ['incomplete', 'pending_approval'])
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['platformCommissionRate', 'workerPayoutRate'])
              || (request.resource.data.get('platformCommissionRate', 0.15) == 0.15
                  && request.resource.data.get('workerPayoutRate', 0.85) == 0.85)
            ));

      // Worker document uploads (subcollection)
      match /documents/{docId} {
        allow read: if isSignedIn()
          && (uid() == workerId || isOwnerOrAdmin());

        // Worker uploads document: status must be pending_review; no review fields.
        allow create: if isOwnerOrAdmin()
          || (isSignedIn() && uid() == workerId
              && request.resource.data.get('status', 'pending_review') == 'pending_review'
              && !request.resource.data.keys()
                   .hasAny(['reviewedAt', 'reviewedByAdminId', 'rejectionReason']));

        // Worker can re-upload (set status back to pending_review); cannot touch review fields.
        allow update: if isOwnerOrAdmin()
          || (isSignedIn() && uid() == workerId
              && !request.resource.data.diff(resource.data).affectedKeys()
                   .hasAny(['reviewedAt', 'reviewedByAdminId', 'rejectionReason'])
              && (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
                || request.resource.data.get('status', '') == 'pending_review'
              ));

        allow delete: if isOwnerOrAdmin();
      }
    }

    // -------------------------------------------------------------------------
    // WORKER DOCUMENTS (flat collection — mirrors subcollection for admin queries)
    // -------------------------------------------------------------------------
    match /workerDocuments/{docId} {
      allow read: if isSignedIn()
        && (resource.data.workerId == uid() || isOwnerOrAdmin());

      allow create: if isOwnerOrAdmin()
        || (isSignedIn()
            && request.resource.data.workerId == uid()
            && request.resource.data.get('status', 'pending_review') == 'pending_review'
            && !request.resource.data.keys()
                 .hasAny(['reviewedAt', 'reviewedByAdminId', 'rejectionReason']));

      allow update: if isOwnerOrAdmin()
        || (isSignedIn()
            && resource.data.workerId == uid()
            && request.resource.data.workerId == uid()
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['reviewedAt', 'reviewedByAdminId', 'rejectionReason'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
              || request.resource.data.get('status', '') == 'pending_review'
            ));

      allow delete: if isOwnerOrAdmin();
    }

    // -------------------------------------------------------------------------
    // WORKER AGREEMENTS
    // -------------------------------------------------------------------------
    match /workerAgreements/{workerId} {
      allow read: if isSignedIn() && (uid() == workerId || isOwnerOrAdmin());
      allow create, update: if isOwnerOrAdmin()
        || (isSignedIn() && uid() == workerId
            && !request.resource.data.keys().hasAny(['reviewedAt', 'reviewedByAdminId']));
    }

    // -------------------------------------------------------------------------
    // DRIVER / WORKER LOCATIONS
    // -------------------------------------------------------------------------
    match /driverLocations/{workerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && uid() == workerId;
    }

    // -------------------------------------------------------------------------
    // SERVICE REQUESTS / JOBS
    // -------------------------------------------------------------------------
    match /serviceRequests/{reqId} {
      allow read, write: if isSignedIn();
    }

    match /jobs/{jobId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    match /jobChats/{jobId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // -------------------------------------------------------------------------
    // NOTIFICATIONS
    // -------------------------------------------------------------------------
    match /notifications/{notifId} {
      // Users read own (userId-tagged) notifications; admin/owner read all.
      allow read: if isSignedIn()
        && (resource.data.get('userId', '') == uid() || isOwnerOrAdmin());
      // Services create notifications on behalf of authenticated users.
      allow create: if isSignedIn();
      // Only admin/owner may mark-read, delete, or modify notifications.
      allow update, delete: if isOwnerOrAdmin();
    }

    // -------------------------------------------------------------------------
    // BUTLER REQUESTS
    // -------------------------------------------------------------------------
    match /butlerRequests/{requestId} {
      // Customer reads own; worker reads pending or own assigned; admin reads all.
      allow read: if isOwnerOrAdmin()
        || (isSignedIn() && resource.data.customerId == uid())
        || (isWorkerOrAdmin()
            && (resource.data.get('status', '') == 'pending'
                || resource.data.get('assignedWorkerId', '') == uid()));

      // Signed-in customer creates own request; must start pending, no worker fields.
      allow create: if isSignedIn()
        && request.resource.data.customerId == uid()
        && request.resource.data.get('status', 'pending') == 'pending'
        && !request.resource.data.keys()
             .hasAny(['assignedWorkerId', 'assignedWorkerName']);

      // Worker claims a pending unassigned request (sets status→assigned, assigns self).
      // Worker updates own assigned request status (pickedUp → onTheWay → delivered).
      // Admin/owner can update anything.
      allow update: if isOwnerOrAdmin()
        || (isWorkerOrAdmin()
            && resource.data.get('status', '') == 'pending'
            && !resource.data.keys().hasAny(['assignedWorkerId'])
            && request.resource.data.get('status', '') == 'assigned'
            && request.resource.data.get('assignedWorkerId', '') == uid()
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['customerId', 'requestType', 'pickupLocation',
                          'dropoffLocation', 'itemDescription']))
        || (isWorkerOrAdmin()
            && resource.data.get('assignedWorkerId', '') == uid()
            && request.resource.data.get('assignedWorkerId', '') == uid()
            && request.resource.data.get('status', '') in
               ['pickedUp', 'onTheWay', 'delivered', 'cancelled']
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['customerId', 'requestType', 'pickupLocation',
                          'dropoffLocation', 'itemDescription']));

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // OTP SESSIONS — backend only (Cloud Functions use Admin SDK, bypass rules)
    // -------------------------------------------------------------------------
    match /whatsappOtpSessions/{sessionId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // DEFAULT — deny everything not explicitly matched above
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
